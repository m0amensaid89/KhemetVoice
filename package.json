{
  "name": "khemet-voice-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:worker": "npm run dev -w apps/agent-worker",
    "build:web": "npm run build -w apps/web",
    "lint:web": "npm run lint -w apps/web"
  }
}
